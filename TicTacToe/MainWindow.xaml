<Window x:Class="TicTacToe.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Tic Tac Toe"
Height="450"
Width="400">
<Grid Margin="20">
<UniformGrid Rows="3" Columns="3">
<Button Name="B0" FontSize="30" Click="Button_Click"/>
<Button Name="B1" FontSize="30" Click="Button_Click"/>
<Button Name="B2" FontSize="30" Click="Button_Click"/>
<Button Name="B3" FontSize="30" Click="Button_Click"/>
<Button Name="B4" FontSize="30" Click="Button_Click"/>
<Button Name="B5" FontSize="30" Click="Button_Click"/>
<Button Name="B6" FontSize="30" Click="Button_Click"/>
<Button Name="B7" FontSize="30" Click="Button_Click"/>
<Button Name="B8" FontSize="30" Click="Button_Click"/>
</UniformGrid>
</Grid>
</Window>